{
  "name": "fgl-youth-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:compat": "vite build --watch --mode development",
    "dev:compat:all": "fuser -k 5173/tcp 5174/tcp 5175/tcp >/dev/null 2>&1 || true && vite build --mode development && vite preview --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-netlify": "latest",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "concurrently": "^9.2.1",
    "svelte": "latest",
    "svelte-check": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "dependencies": {
    "pocketbase": "latest"
  },
  "type": "module"
}
